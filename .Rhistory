rcl <- matrix(
c(
0, 0, NA,
1, 249, 1
),
ncol = 3,
byrow = TRUE)
}
cleaned_r <- terra::classify(r, rcl = rcl, others = NA)
cleaned_r <- terra::classify(r1, rcl = rcl, others = NA)
cleaned_r <- terra::classify(r1, rcl = rcl, others = NA, right = NA)
clean_cicyano <- function(r){
rcl <- matrix(
c(
0, 0, NA,
1, 249, 1,
250, 255, NA
),
ncol = 3,
byrow = TRUE)
}
cleaned_r <- terra::classify(r1, rcl = rcl, others = NA, right = NA)
